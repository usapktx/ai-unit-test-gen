# ─────────────────────────────────────────────────────────────────────────────
#  .NET Unit Test Generator — environment configuration
#
#  Copy this file to .env and fill in your values.
#  .env is loaded automatically at startup; real environment variables always
#  take priority over values in .env.
#
#  Values set here are used as defaults in the UI and can be overridden there.
# ─────────────────────────────────────────────────────────────────────────────

# Internal AI API — base URL (the app appends /chat/completions)
INTERNAL_AI_ENDPOINT=https://internal-ai.example.com/v1

# Authentication credentials for the internal AI gateway
INTERNAL_AI_KEY=your-api-key-here
INTERNAL_AI_SECRET=your-api-secret-here

# Model identifier sent in every request
AI_MODEL=gpt-5
